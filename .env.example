# --------------------------------------------------
# Environment Variables (Example)
# 環境変数（例）
# --------------------------------------------------
# Copy this file to `.env` and fill in values where needed:
# このファイルを `.env` にコピーし、必要な箇所に値を入力してください:
#   cp .env.example .env
#
# ⚠️ Do NOT commit your `.env` file. This file contains placeholders only.
# ⚠️ `.env` ファイルはコミットしないでください。このファイルにはプレースホルダーのみが含まれています。
# --------------------------------------------------

# --------------------------------------------------
# PostgreSQL (used by Docker)
# PostgreSQL (Dockerで使用)
# --------------------------------------------------
# These must match the values defined in docker-compose.yml
# これらはdocker-compose.ymlで定義された値と一致している必要があります

POSTGRES_USER=supplies_user
POSTGRES_PASSWORD=supplies_password
POSTGRES_DB=supplies_db

# --------------------------------------------------
# Prisma Database Connection
# Prisma データベース接続
# --------------------------------------------------
# Used by Prisma when running locally (outside Docker container)
# ローカル環境（Docker コンテナ外）で Prisma を実行する際に使用されます

DATABASE_URL="postgresql://supplies_user:supplies_password@localhost:5432/supplies_db"

# --------------------------------------------------
# Authentication (NextAuth)
# 認証 (NextAuth)
# --------------------------------------------------

# Generate a secure secret with:
# 安全なシークレットを生成するには、以下を実行します：
#   openssl rand -base64 32
NEXTAUTH_SECRET="replace_with_generated_secret"

# Base URL of the application (for local development)
# アプリケーションのベースURL（ローカル開発用
NEXTAUTH_URL="http://localhost:3000"

# --------------------------------------------------
# Notes
# 注記
# --------------------------------------------------
# - No real secrets are included in this file
# - Values here are safe defaults for local development
# - Update DATABASE_URL if using a different DB setup
# - このファイルには実際の機密情報は含まれていません
# - ここにある値は、ローカル開発用の安全なデフォルト設定です
# - 異なるデータベース構成を使用する場合は、DATABASE_URL を更新してください